# ==============================================================================
# PDF TOOLKIT - GITHUB SECRETS TEMPLATE
# ==============================================================================
# Use este arquivo como guia para cadastrar os segredos necessários no repositório
# do GitHub em: Settings -> Secrets and variables -> Actions -> New repository secret.
#
# OBSERVAÇÃO: Nunca envie o arquivo com os valores reais para o repositório Git!
# Este arquivo é apenas um exemplo de estrutura (.env.example).

# ------------------------------------------------------------------------------
# WINDOWS BUILD & CODE SIGNING SECRETS
# ------------------------------------------------------------------------------
# Arquivo do certificado digital do Windows (.pfx) codificado em base64.
# Dica para gerar a base64 no Windows: certutil -encodefile seu_certificado.pfx temp.txt (use o conteudo de temp.txt)
WINDOWS_CERTIFICATE_BASE64=

# Senha de proteção do certificado de Windows (.pfx)
WINDOWS_CERTIFICATE_PASSWORD=

# ------------------------------------------------------------------------------
# MACOS BUILD, CODE SIGNING & NOTARIZATION SECRETS
# ------------------------------------------------------------------------------
# Certificado da Apple (Developer ID Application) em formato .p12 codificado em base64.
MACOS_CERTIFICATE_BASE64=

# Chave de notarização da Apple (App-Specific Password ou API Key de autenticação)
MACOS_NOTARIZATION_KEY=

# ------------------------------------------------------------------------------
# SMTP NOTIFICATION SECRETS (Enviar e-mails com artefatos após build bem-sucedido)
# ------------------------------------------------------------------------------
# Endereço do servidor SMTP (ex.: smtp.gmail.com, smtp.sendgrid.net, etc.)
SMTP_SERVER=

# Porta do servidor SMTP (geralmente 587 para TLS/STARTTLS, ou 465 para SSL)
SMTP_PORT=587

# Usuário de autenticação do servidor SMTP (ex.: seu e-mail de envio)
SMTP_USERNAME=

# Senha de autenticação do servidor SMTP (preferencialmente senha de aplicativo)
SMTP_PASSWORD=

# Endereço de e-mail do destinatário para onde os instaladores compilados serão enviados
NOTIFY_EMAIL_TO=
